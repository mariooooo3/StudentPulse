{
  "name": "studentpulse",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch server/index.js",
    "dev:all": "concurrently -n \"vite,server\" -c \"cyan,yellow\" \"vite\" \"node server/index.js\"",
    "build": "vite build",
    "smoke": "node scripts/smoke-check.mjs",
    "test:api": "node scripts/api-behavior-test.mjs",
    "test:scope": "node --experimental-specifier-resolution=node scripts/scope-personalization-test.mjs",
    "fix:encoding": "node scripts/fix-encoding.mjs",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "pg": "^8.13.0",
    "clsx": "^2.1.1",
    "exifr": "^7.1.3",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^1.2.0",
    "i18next": "^26.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-leaflet": "^4.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "vite": "^6.0.5"
  }
}
